<nav>
  <a href="/" class="logo">
    {% if section.settings.logo != blank %}
      <img src="{{ section.settings.logo | img_url: '100x' }}" alt="{{ shop.name }}">
    {% endif %}
    <div class="logo-text">{{ section.settings.logo_text | replace: 'Klick', '<span>Klick</span>' }}</div>
  </a>
  <ul>
    {% for link in linklists[section.settings.menu].links %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
    {% endfor %}
  </ul>
  <a href="{{ section.settings.cta_link }}" class="nav-cta">{{ section.settings.cta_text }}</a>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "text", "id": "logo_text", "label": "Logo Text", "default": "My Klick Shop" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Explorar" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" }
  ]
}
{% endschema %}
